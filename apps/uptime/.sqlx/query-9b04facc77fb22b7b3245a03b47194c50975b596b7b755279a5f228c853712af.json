{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT o.origin_uid, o.uri, q.status, q.latency_millis, q.queried_at\n            FROM origin o\n            JOIN LATERAL (\n                SELECT status, latency_millis, queried_at\n                FROM query\n                WHERE origin_id = o.id\n                ORDER BY queried_at DESC\n                LIMIT 1\n            ) q ON true\n        ",
